{
  "name": "@app-manager/server",
  "version": "0.5.1",
  "description": "App manager 服务端 - tRPC + Fastify + Drizzle ORM + PostgreSQL",
  "author": "Jaxon",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/trpc/router.d.ts",
      "import": "./dist/trpc/router.js",
      "default": "./src/trpc/router.ts"
    }
  },
  "types": "./dist/trpc/router.d.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && cp src/app_settings/chatq/data/personaDimensions.json dist/app_settings/chatq/data/ 2>/dev/null || true",
    "start": "node dist/index.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx scripts/seed-chatq-data.ts"
  },
  "dependencies": {
    "@trpc/server": "11.9.0",
    "dotenv": "^16.4.0",
    "drizzle-orm": "^0.38.0",
    "fastify": "^5.2.0",
    "jsonwebtoken": "^9.0.3",
    "pino-pretty": "^13.1.3",
    "postgres": "^3.4.0",
    "trpc-to-openapi": "^3.1.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.0.0",
    "drizzle-kit": "^0.30.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
